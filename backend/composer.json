{
  "name": "yurimotatech/gran-study-planner-backend",
  "description": "Hexagonal backend for Gran Study Planner",
  "type": "project",
  "require": {
    "php": "^8.3",
    "ext-pdo": "*",
    "symfony/event-dispatcher": "^7.0",
    "symfony/mailer": "^7.0",
    "symfony/mime": "^7.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "GranStudyPlanner\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "GranStudyPlanner\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "serve": "php -S 0.0.0.0:8080 -t public"
  }
}
