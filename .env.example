APP_ENV=dev
APP_DEBUG=true
APP_URL=http://localhost:8080
FRONTEND_URL=http://localhost:5173

DB_HOST=db
DB_PORT=3306
DB_NAME=gran_study
DB_USER=gran
DB_PASSWORD=gran

REDIS_HOST=redis
REDIS_PORT=6379

AUTH_JWT_SECRET=change-me-in-production
AUTH_TOKEN_TTL=3600
DASHBOARD_CACHE_TTL=120
LOG_LEVEL=info

# Daily summary email (run: php bin/send_daily_summary.php; requires MAIL_TO + MAILER_DSN)
DAILY_SUMMARY_ENABLED=true
MAIL_TO=
MAIL_FROM=noreply@localhost
MAIL_FROM_NAME=Gran Study Planner
MAILER_DSN=
DAILY_SUMMARY_USER_ID=1
